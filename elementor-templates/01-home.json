          "elements": [
            {
              "id": "9a6d2f3",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "\n<section style=\"padding:100px 5%;background:#fff\">\n  <div style=\"text-align:center;margin-bottom:56px\">\n    <span style=\"display:inline-block;color:#09a38c;font-size:0.78rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:14px\">What We Do</span>\n    <h2 style=\"font-size:clamp(1.7rem,3vw,2.6rem);font-weight:800;color:#0a1628;margin-bottom:20px\">Comprehensive Clean Energy Solutions</h2>\n    <p style=\"font-size:1.05rem;color:#64748b;line-height:1.75;max-width:640px;margin:0 auto\">Eight integrated domains designed to accelerate the global transition to sustainable, zero-emission energy systems.</p>\n  </div>\n  <div style=\"display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px\">\n<div style=\"border:1px solid #dce4ef;border-radius:16px;padding:32px;background:#fff\"><div style=\"font-size:2rem;margin-bottom:16px\">🏗️</div><h3 style=\"font-size:1rem;font-weight:700;color:#0a1628;margin-bottom:10px\">Power Grid Modernization &amp; Power Plant Integration in Mexico</h3><p style=\"font-size:0.86rem;color:#64748b;line-height:1.65\">Advanced grid infrastructure upgrades and integration of clean generation technologies across Mexico's energy network.</p></div><div style=\"border:1px solid #dce4ef;border-radius:16px;padding:32px;background:#fff\"><div style=\"font-size:2rem;margin-bottom:16px\">☀️</div><h3 style=\"font-size:1rem;font-weight:700;color:#0a1628;margin-bottom:10px\">Renewable Energy Generation: Solar, Wind &amp; Water Solar</h3><p style=\"font-size:0.86rem;color:#64748b;line-height:1.65\">Scalable renewable generation combining photovoltaic, onshore/offshore wind, and novel water-based solar technologies.</p></div><div style=\"border:1px solid #dce4ef;border-radius:16px;padding:32px;background:#fff\"><div style=\"font-size:2rem;margin-bottom:16px\">⚗️</div><h3 style=\"font-size:1rem;font-weight:700;color:#0a1628;margin-bottom:10px\">Hydrogen Production &amp; Dispensing Systems</h3><p style=\"font-size:0.86rem;color:#64748b;line-height:1.65\">End-to-end green and blue hydrogen production, compression, storage, and public/commercial dispensing infrastructure.</p></div><div style=\"border:1px solid #dce4ef;border-radius:16px;padding:32px;background:#fff\"><div style=\"font-size:2rem;margin-bottom:16px\">🔋</div><h3 style=\"font-size:1rem;font-weight:700;color:#0a1628;margin-bottom:10px\">Methanol Fuel Cell Power &amp; Range Extenders</h3><p style=\"font-size:0.86rem;color:#64748b;line-height:1.65\">High-efficiency methanol fuel cell systems for stationary power and range-extending applications in commercial fleets.</p></div><div style=\"border:1px solid #dce4ef;border-radius:16px;padding:32px;background:#fff\"><div style=\"font-size:2rem;margin-bottom:16px\">🏭</div><h3 style=\"font-size:1rem;font-weight:700;color:#0a1628;margin-bottom:10px\">LNG Onshore Regasification &amp; Infrastructure</h3><p style=\"font-size:0.86rem;color:#64748b;line-height:1.65\">Full-cycle onshore LNG regasification terminal design, procurement, construction, and operations management.</p></div><div style=\"border:1px solid #dce4ef;border-radius:16px;padding:32px;background:#fff\"><div style=\"font-size:2rem;margin-bottom:16px\">🚢</div><h3 style=\"font-size:1rem;font-weight:700;color:#0a1628;margin-bottom:10px\">Offshore Floating Storage &amp; Regasification (FSRU)</h3><p style=\"font-size:0.86rem;color:#64748b;line-height:1.65\">Offshore FSRU deployment and operations enabling rapid LNG import capacity expansion without onshore construction.</p></div><div style=\"border:1px solid #dce4ef;border-radius:16px;padding:32px;background:#fff\"><div style=\"font-size:2rem;margin-bottom:16px\">🌐</div><h3 style=\"font-size:1rem;font-weight:700;color:#0a1628;margin-bottom:10px\">Overseas LNG Supply Chain Management</h3><p style=\"font-size:0.86rem;color:#64748b;line-height:1.65\">Integrated international LNG sourcing, shipping logistics, scheduling, and supply chain optimization services.</p></div><div style=\"border:1px solid #dce4ef;border-radius:16px;padding:32px;background:#fff\"><div style=\"font-size:2rem;margin-bottom:16px\">🚗</div><h3 style=\"font-size:1rem;font-weight:700;color:#0a1628;margin-bottom:10px\">E-Mobility Integration &amp; Commercial EVs</h3><p style=\"font-size:0.86rem;color:#64748b;line-height:1.65\">Fleet electrification strategy, EV infrastructure deployment, and commercial electric vehicle integration programs.</p></div></div></section>"
              },
              "elements": []
            }
          ],
          "isInner": false
        }
