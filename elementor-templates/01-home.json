              "id": "4893fc5",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "\n<div style=\"background:linear-gradient(135deg,#0f3460,#1a4a8a);padding:80px 5%;text-align:center;color:#fff\">\n  <div style=\"max-width:860px;margin:0 auto\">\n    <div style=\"font-size:clamp(3rem,7vw,6rem);font-weight:900;color:#0ccfb0;margin-bottom:16px\">70%+</div>\n    <p style=\"font-size:clamp(1rem,2vw,1.35rem);color:rgba(255,255,255,0.85);line-height:1.7;margin-bottom:12px\">of global warming emissions come from the energy sector</p>\n    <p style=\"font-size:0.95rem;color:rgba(255,255,255,0.55)\">Annually, nearly 40 billion tons of carbon dioxide are released into the atmosphere by our global energy systems.</p>\n    <div style=\"display:inline-block;margin-top:20px;background:rgba(255,255,255,0.1);border-radius:8px;padding:12px 20px;font-size:0.85rem;color:rgba(255,255,255,0.65);max-width:600px\">As the urgency of the climate crisis becomes clearer, we support the development of technology innovations, emissions regulations, and policy pathways designed to enable a net-zero emissions future by 2050.</div>\n  </div>\n</div>"
              },
              "elements": []
            }
          ],
          "isInner": false
        }
